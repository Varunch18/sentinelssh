# ----------------------------------------------------------------------------
# SentinelSSH — Docker Compose environment template.
# Copy to `.env` (same directory as docker-compose.yml) and adjust before
# running `docker compose up --build`. All values have safe defaults in the
# compose file, but you SHOULD change the secrets below for any real deployment.
# ----------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinelssh

# --- Backend / dashboard ---
# Flask session signing key — CHANGE THIS to a long random string in production.
SECRET_KEY=change-me-in-production
# Set true only when serving over HTTPS (e.g. behind nginx + TLS in Phase 12).
SESSION_COOKIE_SECURE=false
# Allowed CORS origins for the API ("*" is fine for same-origin demo).
CORS_ORIGINS=*

# Seed realistic demo data on first boot so the dashboard is populated.
# Set to false for a clean production instance that fills from live attacks.
DEMO_MODE=true

# Default dashboard login created on first boot (idempotent).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sentinel123

# --- Shared honeypot <-> backend secret ---
# Authenticates the honeypot's real-time event pushes to the backend.
INTERNAL_API_TOKEN=change-this-internal-token

# --- Honeypot ---
# Host port that maps to the container's SSH listener (container side is 2222).
# Use 22 to capture real internet scans on a VPS (Phase 12).
HONEYPOT_PUBLISH_PORT=2222
# Optional IP threat feed (one CIDR/IP per line) mounted into the honeypot.
# THREAT_FEED_PATH=/app/data/threat_feed.txt
