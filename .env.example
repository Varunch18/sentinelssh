# ----------------------------------------------------------------------------
# SentinelSSH environment configuration (copy to .env and adjust)
# ----------------------------------------------------------------------------

# --- Honeypot (Phase 2) ---
HONEYPOT_HOST=0.0.0.0
HONEYPOT_PORT=2222
HONEYPOT_BANNER=SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.4
HONEYPOT_HOSTNAME=srv01
HONEYPOT_HOST_KEY=keys/host_rsa.key
HONEYPOT_HOST_KEY_BITS=2048
HONEYPOT_AUTH_TIMEOUT=30
HONEYPOT_SESSION_TIMEOUT=300
HONEYPOT_MAX_AUTH_ATTEMPTS=6
HONEYPOT_MAX_COMMANDS=100
HONEYPOT_JSONL=data/captures.jsonl
HONEYPOT_LOG_STDOUT=true

# --- Database (used from Phase 3 onward) ---
# Development (SQLite):
DATABASE_URL=sqlite:///data/sentinelssh.sqlite3
# Production (PostgreSQL) example:
# DATABASE_URL=postgresql+psycopg2://sentinel:changeme@db:5432/sentinelssh

# --- Threat intelligence (Phase 4) ---
THREAT_FEED_PATH=data/threat_feed.txt
# GEOIP_CITY_DB=data/GeoLite2-City.mmdb
# GEOIP_ASN_DB=data/GeoLite2-ASN.mmdb

# --- Backend API (Phase 5) ---
PORT=8008
FLASK_ENV=development
CORS_ORIGINS=*

# --- Real-time (Phase 6) ---
# Shared secret between honeypot and backend for the internal event endpoint.
INTERNAL_API_TOKEN=change-this-internal-token
# Honeypot -> backend broadcast endpoint (leave empty to disable realtime push).
INTERNAL_EVENTS_URL=http://localhost:8008/api/internal/events
# Optional Redis message queue for multi-worker SocketIO fan-out.
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0
